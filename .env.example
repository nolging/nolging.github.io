# Supabase 프로젝트 설정값 (Supabase 대시보드 > Project Settings > API)
# 이 두 값은 공개되어도 안전합니다(anon 키는 RLS로 보호됨).
# 실제 값을 넣어 .env.local 로 복사해서 사용하세요:  cp .env.example .env.local

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 로그인 시 닉네임에 붙이는 내부 이메일 도메인 (변경 불필요)
VITE_EMAIL_DOMAIN=nolging.app
